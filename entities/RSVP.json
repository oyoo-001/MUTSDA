{
  "name": "RSVP",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "description": "ID of the event"
    },
    "member_email": {
      "type": "string",
      "description": "Email of the member RSVPing"
    },
    "member_name": {
      "type": "string",
      "description": "Name of the member"
    },
    "status": {
      "type": "string",
      "enum": [
        "attending",
        "not_attending",
        "maybe"
      ],
      "default": "attending",
      "description": "RSVP status"
    },
    "guests": {
      "type": "number",
      "default": 0,
      "description": "Number of additional guests"
    }
  },
  "required": [
    "event_id",
    "member_email"
  ]
}